# Copy this file to .env and fill in your deployed URLs.
# On Vercel, set these as Environment Variables in the project dashboard.

# Your Render backend WebSocket URL (wss:// for HTTPS deployments)
VITE_WS_URL=wss://your-app-name.onrender.com/ws

# Your Render backend HTTP URL
VITE_API_URL=https://your-app-name.onrender.com
